{
  "name": "wc2026-predictor",
  "version": "1.0.0",
  "description": "FIFA World Cup 2026 prediction game — leaderboard + per-player pages, static site",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "parse-template": "node scripts/parse-template.js",
    "fetch:schedule": "node --env-file=.env scripts/fetch-schedule.js",
    "ingest": "node scripts/ingest.js",
    "links": "node scripts/list-links.js",
    "generate-samples": "node scripts/generate-samples.js",
    "clean": "node -e \"require('fs').rmSync('_site',{recursive:true,force:true})\"",
    "build:css": "npx tailwindcss -i ./src/styles/input.css -o ./_site/assets/css/tailwind.css --minify",
    "build:site": "npx @11ty/eleventy",
    "build:digest": "node scripts/build-digest.js",
    "build": "npm run clean && npm run build:css && npm run build:site && npm run build:digest",
    "test": "node --test scripts/*.test.js",
    "deploy": "npm test && npm run fetch:schedule && npm run ingest && node scripts/deploy-gh-pages.js",
    "admin": "node scripts/admin-server.js",
    "send-links": "node scripts/send-player-links.js",
    "send-links:dry": "node scripts/send-player-links.js --dry-run"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
