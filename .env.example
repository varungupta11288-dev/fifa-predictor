# Copy this file to .env and fill in a real secret. .env is gitignored.
#
# Generate a random secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# The secret is mixed into every per-player URL token (sha256(SECRET + email)).
# DO NOT change it once players have been given their URLs — every existing
# /me/<token>/ link will break.
PREDICTOR_SECRET=replace-with-32-bytes-of-random-hex
