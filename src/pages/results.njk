---
layout: layout.njk
title: Results — WC2026 Predictor
permalink: /results/index.html
---
<h1 class="text-2xl font-bold mb-1">Match results</h1>
<p class="text-sm text-slate-600 mb-6">{{ results.length }} completed match(es)</p>

{% if results.length == 0 %}
  <p class="text-slate-500">No results recorded yet.</p>
{% else %}
<div class="overflow-x-auto bg-white rounded shadow-sm border border-slate-200">
<table class="min-w-full text-sm">
  <thead class="bg-slate-100">
    <tr>
      <th class="text-left p-2 font-semibold">Date</th>
      <th class="text-left p-2 font-semibold">Match</th>
      <th class="text-left p-2 font-semibold">Stage</th>
      <th class="text-left p-2 font-semibold">Fixture</th>
      <th class="text-right p-2 font-semibold">Score</th>
      <th class="text-left p-2 font-semibold">Winner</th>
    </tr>
  </thead>
  <tbody>
  {% for r in results %}
    <tr class="border-t border-slate-100">
      <td class="p-2 text-slate-500">{{ r.actualDate }}</td>
      <td class="p-2 text-slate-500">{{ r.matchId }}</td>
      <td class="p-2 uppercase text-xs">{{ r.stage }}</td>
      <td class="p-2">{{ r.home }} v {{ r.away }}</td>
      <td class="p-2 text-right">{{ r.homeScore }}–{{ r.awayScore }}</td>
      <td class="p-2">{{ r.winner if r.winner != null else 'Draw' }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% endif %}
