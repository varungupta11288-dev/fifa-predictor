---
layout: layout.njk
pagination:
  data: playerViews
  size: 1
  alias: player
permalink: "/me/{{ player.token }}/index.html"
eleventyComputed:
  title: "Predictions — {{ player.handle }}"
---
{# Stage accent colours mirror the leaderboard's stage legend on the home page. #}
{% set stageColors = { r32: '#0ea5e9', r16: '#6366f1', qf: '#a855f7', sf: '#ec4899', final: '#f97316' } %}

{# Reusable flag + team cells — same treatment as the Fixtures page. #}
{% macro flag(team) %}
  {% if team and team.iso2 %}
    <img class="fx-flag" src="https://flagcdn.com/24x18/{{ team.iso2 }}.png"
         srcset="https://flagcdn.com/48x36/{{ team.iso2 }}.png 2x"
         width="24" height="18" loading="lazy" alt="{{ team.name }}">
  {% else %}
    <span class="fx-flag fx-flag--tbd" aria-hidden="true"></span>
  {% endif %}
{% endmacro %}

{% macro teamCell(team, side) %}
  <span class="fx-team">
    {% if side == 'away' %}<span class="fx-name">{{ team.name }}</span>{% endif %}
    {{ flag(team) }}
    {% if side == 'home' %}<span class="fx-name">{{ team.name }}</span>{% endif %}
  </span>
{% endmacro %}

<a href="{{ site.baseUrl }}/" class="inline-flex items-center gap-1 text-sm text-pitch-700 font-semibold hover:underline mb-4">← Leaderboard</a>

{# ── Header ─────────────────────────────────────────────────────────────── #}
<section class="mb-8">
  <p class="text-xs uppercase tracking-[0.25em] text-pitch-700 font-semibold mb-1">Predictions</p>
  <h1 class="display text-3xl md:text-4xl text-slate-900">{{ player.name }}</h1>
  <p class="text-sm text-slate-600 mt-2">
    handle <span class="font-semibold text-slate-700">{{ player.handle }}</span>
    · submitted {{ player.submittedAt }}
    · tie-breaker <span class="font-semibold text-slate-700">{{ player.tiebreaker }}</span> goals
    · winner pick <span class="font-semibold text-slate-700">{{ player.winner or '—' }}</span>
    {% if player.winnerHit %}<span class="text-emerald-700 font-semibold">✓ +{{ player.winnerPoints }}</span>{% endif %}
  </p>
</section>

{% if player.warnings and player.warnings.length > 0 %}
<details class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm mb-8">
  <summary class="font-medium cursor-pointer">{{ player.warnings.length }} ingestion warning(s)</summary>
  <ul class="list-disc list-inside mt-2 text-amber-900">
    {% for w in player.warnings %}<li>{{ w }}</li>{% endfor %}
  </ul>
</details>
{% endif %}

{# ── Group stage ────────────────────────────────────────────────────────── #}
<section class="mb-12">
  <h2 class="display text-xl text-slate-800 mb-4">Group Stage</h2>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {% for group in player.groupSections %}
      <div>
        <h3 class="fx-group-title">{{ group.title }}</h3>
        <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-slate-200">
          <table class="fx-table w-full text-sm">
            <thead class="bg-slate-50 text-slate-600">
              <tr class="text-[11px] uppercase tracking-wider">
                <th class="text-right  p-2 font-semibold">Home</th>
                <th class="text-center p-2 font-semibold w-6"></th>
                <th class="text-left   p-2 font-semibold">Away</th>
                <th class="text-center p-2 font-semibold w-16">Pred</th>
                <th class="text-center p-2 font-semibold w-14">Result</th>
                <th class="text-right  p-2 font-semibold w-10">Pts</th>
              </tr>
            </thead>
            <tbody>
              {% for row in group.rows %}
                <tr class="border-t border-slate-100 align-middle{% if row.outcomeClass == 'exact' %} bg-emerald-50{% elif row.outcomeClass == 'result' %} bg-sky-50{% elif row.outcomeClass == 'wrong' %} bg-rose-50{% endif %}">
                  <td class="p-2 text-right">{{ teamCell(row.home, 'home') }}</td>
                  <td class="p-2 text-center text-slate-400 text-xs">v</td>
                  <td class="p-2 text-left">{{ teamCell(row.away, 'away') }}</td>
                  <td class="p-2 text-center">
                    {% if row.predicted %}<span class="font-semibold text-slate-700 tabular-nums">{{ row.predicted.home }}–{{ row.predicted.away }}</span>{% else %}<span class="text-slate-300">—</span>{% endif %}
                  </td>
                  <td class="p-2 text-center">
                    {% if row.actual %}<span class="fx-score tabular-nums">{{ row.actual.homeScore }}–{{ row.actual.awayScore }}</span>{% else %}<span class="text-slate-300">—</span>{% endif %}
                  </td>
                  <td class="p-2 text-right font-semibold tabular-nums">{% if row.points != null %}{{ row.points }}{% else %}<span class="text-slate-300">—</span>{% endif %}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{# ── Knockout picks ─────────────────────────────────────────────────────── #}
<section>
  <h2 class="display text-xl text-slate-800 mb-4">Knockout Picks</h2>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {% for section in player.knockoutSections %}
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="fx-group-title mb-0">{{ section.label }}</h3>
        <span class="chip" style="--chip-color: {{ stageColors[section.stage] or '#64748b' }}">{{ section.pointsPer }} pt/team</span>
      </div>
      {% if section.picks.length == 0 %}
        <p class="text-xs text-slate-400">No picks recorded.</p>
      {% else %}
        <ul class="text-sm space-y-1.5">
          {% for p in section.picks %}
            <li class="flex items-center justify-between {% if p.hit %}text-emerald-700 font-semibold{% else %}text-slate-700{% endif %}">
              <span>{{ p.team }}</span>
              {% if p.hit %}<span class="text-xs">✓ +{{ p.pointsIfHit }}</span>{% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endfor %}
  </div>
</section>
