---
layout: layout.njk
title: Leaderboard — WC2026 Predictor
permalink: /index.html
---
{% set leader = leaderboard[0] %}
{% set maxScore = 960 %}

<section class="mb-8">
  <p class="text-xs uppercase tracking-[0.25em] text-pitch-700 font-semibold mb-1">Standings</p>
  <h1 class="display text-3xl md:text-4xl text-slate-900">Leaderboard</h1>
  <p class="text-sm text-slate-600 mt-2">
    {{ leaderboard.length }} player{{ 's' if leaderboard.length != 1 else '' }}
    · {{ results.length }} match{{ 'es' if results.length != 1 else '' }} scored
    · updated {{ site.lastUpdatedShort }}
  </p>
</section>

{% if leaderboard.length == 0 %}
  <div class="bg-white border border-slate-200 rounded-lg p-10 text-center text-slate-500">
    No predictions ingested yet.
  </div>
{% else %}

{# ─── Podium (top 3) ───────────────────────────────────────────────────── #}
{% if leaderboard.length >= 3 %}
<section class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
  {% for entry in leaderboard.slice(0, 3) %}
    {% set rankClass = 'rank-' ~ loop.index %}
    {% set medalLabel = ['🥇','🥈','🥉'][loop.index0] %}
    {% set behind = leader.totalPoints - entry.totalPoints %}
    <article class="podium-card {{ rankClass }} {% if loop.index == 1 %}animate-goldGlow{% endif %}">
      <div class="flex items-center gap-3">
        <span class="medal text-lg">{{ loop.index }}</span>
        <div>
          <p class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">
            {% if loop.index == 1 %}Leader{% elif loop.index == 2 %}2nd place{% else %}3rd place{% endif %}
          </p>
          <p class="display text-lg text-slate-900">{{ entry.handle }}</p>
        </div>
      </div>
      <div class="mt-4 flex items-end justify-between">
        <span class="display text-4xl text-slate-900">{{ entry.totalPoints }}</span>
        <span class="text-xs text-slate-500">
          {% if loop.index == 1 %}
            <span class="text-champ-600 font-semibold">{{ medalLabel }} top of the table</span>
          {% else %}
            {{ behind }} pt behind leader
          {% endif %}
        </span>
      </div>
      <div class="mt-3">
        <div class="bar {% if loop.index == 1 %}bar-gold{% endif %}">
          <i class="animate-barFill" style="width: {{ (entry.totalPoints / maxScore * 100) | round(1) }}%; animation-delay: {{ loop.index0 * 120 }}ms"></i>
        </div>
        <p class="text-[10px] text-slate-500 mt-1">{{ (entry.totalPoints / maxScore * 100) | round(1) }}% of max ({{ maxScore }})</p>
      </div>
    </article>
  {% endfor %}
</section>
{% endif %}

{# ─── Full table ───────────────────────────────────────────────────────── #}
<section>
  <h2 class="display text-lg text-slate-700 mb-3">Full standings</h2>
  <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-slate-200">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-50 text-slate-600">
      <tr class="text-[11px] uppercase tracking-wider">
        <th class="text-left  p-3 font-semibold w-12">#</th>
        <th class="text-left  p-3 font-semibold">Player</th>
        <th class="text-left  p-3 font-semibold w-64">Progress</th>
        <th class="text-right p-3 font-semibold w-16">Total</th>
        <th class="text-left  p-3 font-semibold">Stages</th>
        <th class="text-right p-3 font-semibold w-14">TB</th>
      </tr>
    </thead>
    <tbody>
    {% for entry in leaderboard %}
      {% set isLeader = loop.index == 1 and entry.totalPoints > 0 %}
      <tr class="lb-row border-t border-slate-100 relative {% if isLeader %}gold-shimmer animate-goldShimmer{% endif %}">
        <td class="p-3 align-middle">
          {% if loop.index <= 3 and entry.totalPoints > 0 %}
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-[11px] font-bold
              {% if loop.index == 1 %}bg-champ-400 text-champ-700
              {% elif loop.index == 2 %}bg-slate-200 text-slate-700
              {% else %}bg-orange-200 text-orange-800{% endif %}">
              {{ loop.index }}
            </span>
          {% else %}
            <span class="text-slate-400 pl-1">{{ loop.index }}</span>
          {% endif %}
        </td>
        <td class="p-3 align-middle">
          <span class="font-semibold text-slate-900">{{ entry.handle }}</span>
        </td>
        <td class="p-3 align-middle">
          <div class="bar {% if isLeader %}bar-gold{% endif %}">
            <i class="animate-barFill" style="width: {{ (entry.totalPoints / maxScore * 100) | round(1) }}%; animation-delay: {{ loop.index0 * 60 }}ms"></i>
          </div>
        </td>
        <td class="p-3 align-middle text-right">
          <span class="display text-lg {% if isLeader %}text-champ-700{% else %}text-slate-900{% endif %}">{{ entry.totalPoints }}</span>
        </td>
        <td class="p-3 align-middle">
          <div class="flex flex-wrap gap-1">
            {% if entry.pointsByStage.group > 0 %}
              <span class="chip" style="--chip-color: #0b6b3a">G {{ entry.pointsByStage.group }}</span>
            {% endif %}
            {% if entry.pointsByStage.r32 > 0 %}
              <span class="chip" style="--chip-color: #0ea5e9">R32 {{ entry.pointsByStage.r32 }}</span>
            {% endif %}
            {% if entry.pointsByStage.r16 > 0 %}
              <span class="chip" style="--chip-color: #6366f1">R16 {{ entry.pointsByStage.r16 }}</span>
            {% endif %}
            {% if entry.pointsByStage.qf > 0 %}
              <span class="chip" style="--chip-color: #a855f7">QF {{ entry.pointsByStage.qf }}</span>
            {% endif %}
            {% if entry.pointsByStage.sf > 0 %}
              <span class="chip" style="--chip-color: #ec4899">SF {{ entry.pointsByStage.sf }}</span>
            {% endif %}
            {% if entry.pointsByStage.final > 0 %}
              <span class="chip" style="--chip-color: #f97316">Final {{ entry.pointsByStage.final }}</span>
            {% endif %}
            {% if entry.pointsByStage.winner > 0 %}
              <span class="chip" style="--chip-color: #b08323">🏆 Winner {{ entry.pointsByStage.winner }}</span>
            {% endif %}
            {% if entry.totalPoints == 0 %}
              <span class="text-slate-400 text-xs italic">no points yet</span>
            {% endif %}
          </div>
        </td>
        <td class="p-3 align-middle text-right text-slate-500 text-xs">
          {{ entry.tiebreaker if entry.tiebreaker != null else '—' }}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  <p class="text-xs text-slate-500 mt-3">
    <strong>Progress</strong> bar = points / 960 max ·
    <strong>TB</strong> = tie-breaker prediction (total goals across all 104 matches, incl. extra time)
  </p>
</section>

{% endif %}
