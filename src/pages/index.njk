---
layout: layout.njk
title: Leaderboard — WC2026 Predictor
permalink: /index.html
---
{% set leader = leaderboard[0] %}
{% set maxScore = 960 %}

{# ─── Entry modal ─────────────────────────────────────────────────────────
   One modal greets the visitor on each new state, then reveals the leaderboard
   when closed. Three states drive its content:
     • pre   — countdown to kickoff
     • live  — the day's fixtures as cards (today, or the next match day)
     • done  — a closing thank-you
   `modalKey` is what we remember as "seen" in localStorage; for the live state
   it includes the focus date so a new match day re-opens the modal. #}
{% if site.tournamentFinished %}{% set modalState = 'done' %}
{% elif site.tournamentLive %}{% set modalState = 'live' %}
{% else %}{% set modalState = 'pre' %}{% endif %}
{% set modalKey = modalState %}
{% if modalState == 'live' and schedule.today.iso %}{% set modalKey = 'live:' ~ schedule.today.iso %}{% endif %}

{% macro modalFlag(team) %}
  {%- if team and team.iso2 -%}
    <img class="modal-match-flag" src="https://flagcdn.com/24x18/{{ team.iso2 }}.png"
         srcset="https://flagcdn.com/48x36/{{ team.iso2 }}.png 2x" width="24" height="18" loading="lazy" alt="">
  {%- else -%}
    <span class="modal-match-flag modal-match-flag--tbd" aria-hidden="true"></span>
  {%- endif -%}
{% endmacro %}

{# Before the leaderboard below is parsed/painted, decide whether the modal will
   show. If it's already been dismissed for this state, reveal the board straight
   away; otherwise gate its entrance animations until the modal is closed. #}
<script>
(function () {
  document.documentElement.classList.add('lb-gated');
})();
</script>

<div id="wc-modal" class="countdown-modal" role="dialog" aria-modal="true" aria-labelledby="wc-modal-title">
  <div class="countdown-modal__panel">
    <button type="button" class="countdown-modal__close" data-close aria-label="Close">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6 L18 18 M18 6 L6 18"/>
      </svg>
    </button>

    {% if modalState == 'pre' %}
    <div class="countdown-modal__content">
      <p id="wc-modal-title" class="countdown-modal__eyebrow">FIFA World Cup 2026 kicks off in</p>
      <div class="countdown-display">
        <img class="countdown-trophy countdown-trophy--left" src="{{ site.baseUrl }}/assets/trophy.webp" alt="" aria-hidden="true">
        <div class="countdown-numbers">
          <div><span class="countdown-num" data-d>--</span><span class="countdown-label">Days</span></div>
          <div><span class="countdown-num" data-h>--</span><span class="countdown-label">Hours</span></div>
          <div><span class="countdown-num" data-m>--</span><span class="countdown-label">Min</span></div>
          <div><span class="countdown-num" data-s>--</span><span class="countdown-label">Sec</span></div>
        </div>
        <img class="countdown-trophy countdown-trophy--right" src="{{ site.baseUrl }}/assets/trophy.webp" alt="" aria-hidden="true">
      </div>
      <p class="countdown-modal__sub">USA · Canada · Mexico · 11 Jun 2026</p>
      <a href="{{ site.baseUrl }}/how-to-enter/" class="countdown-modal__cta">How to enter →</a>
    </div>

    {% elif modalState == 'live' %}
    <div class="countdown-modal__content countdown-modal__content--matches">
      <p id="wc-modal-title" class="countdown-modal__eyebrow">
        {% if schedule.today.isToday %}Today's matches{% else %}Next up{% endif %}
      </p>
      {% if schedule.today.label %}<p class="modal-matchday">{{ schedule.today.label }}</p>{% endif %}
      {% if schedule.today.matches.length %}
      <div class="modal-match-list">
        {% for m in schedule.today.matches %}
        <div class="modal-match-card">
          <div class="modal-match-meta">
            <span>{{ m.stageLabel }}</span>
            <span class="tabular-nums">{{ m.timeLabel }} UTC</span>
          </div>
          <div class="modal-match-teams">
            <span class="modal-match-team">{{ modalFlag(m.home) }}<span>{{ m.home.name if m.home else 'TBD' }}</span></span>
            <span class="modal-match-vs">{% if m.finished %}{{ m.score.home }}–{{ m.score.away }}{% else %}v{% endif %}</span>
            <span class="modal-match-team modal-match-team--away"><span>{{ m.away.name if m.away else 'TBD' }}</span>{{ modalFlag(m.away) }}</span>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <p class="countdown-modal__sub">No matches scheduled.</p>
      {% endif %}
      <button type="button" class="countdown-modal__cta" data-close>View leaderboard →</button>
    </div>

    {% else %}
    <div class="countdown-modal__content">
      <img class="modal-thanks-trophy" src="{{ site.baseUrl }}/assets/trophy.webp" alt="" aria-hidden="true">
      <p id="wc-modal-title" class="countdown-modal__eyebrow">FIFA World Cup 2026</p>
      <h2 class="modal-thanks-title display">Thanks for playing!</h2>
      <p class="modal-thanks-text">That's a wrap on the tournament. Thank you for taking part in the WC2026 Predictor — we hope you enjoyed every twist of the bracket.</p>
      <button type="button" class="countdown-modal__cta" data-close>View final leaderboard →</button>
    </div>
    {% endif %}
  </div>
</div>

<section class="mb-8">
  <p class="text-xs uppercase tracking-[0.25em] text-pitch-700 font-semibold mb-1">Standings</p>
  <h1 class="display text-3xl md:text-4xl text-slate-900">Leaderboard</h1>
  <p class="text-sm text-slate-600 mt-2">
    {{ leaderboard.length }} player{{ 's' if leaderboard.length != 1 else '' }}
    · {{ results.length }} match{{ 'es' if results.length != 1 else '' }} scored
    · updated {{ site.lastUpdatedShort }}
  </p>
</section>

{% if leaderboard.length == 0 %}
  <div class="bg-white border border-slate-200 rounded-lg p-10 text-center text-slate-500">
    No predictions ingested yet.
  </div>
{% else %}

<div class="lb-demo-wrap">
{# Tiled diagonal "DEMO DATA" watermark across the standings — pre-kickoff only.
   `tournamentLive` flips true at build on 11 Jun 2026 (src/_data/site.js), so
   the watermark drops automatically once real results start being scored. #}
{% if not site.tournamentLive and not site.tournamentFinished %}
<div class="demo-watermark" aria-hidden="true"></div>
{% endif %}

{# ─── Podium (top 3) ───────────────────────────────────────────────────── #}
{# Visual order is 2-1-3 (silver · gold · bronze) via CSS `order` on sm+; the   #}
{# loop stays in rank order so the markup/DOM remains 1-2-3 for accessibility.  #}
{# Hidden while every player is on 0 pts (podium would be three names with     #}
{# identical empty bars) — the dribble banner below stands in until points land. #}
{% if leaderboard.length >= 3 and leader.totalPoints > 0 %}
<section class="podium flex flex-col sm:flex-row sm:items-end gap-4 mb-10">
  {% for entry in leaderboard.slice(0, 3) %}
    {% set rankClass = 'rank-' ~ loop.index %}
    {% set medalLabel = ['🥇','🥈','🥉'][loop.index0] %}
    {% set behind = leader.totalPoints - entry.totalPoints %}
    {# Bronze rises first, then silver, then gold lands last for the build-up. #}
    {% set riseDelay = (3 - loop.index) * 140 %}
    <article class="podium-card {{ rankClass }} flex-1{% if loop.index == 1 %} podium-card--leader{% endif %}">
      {% if loop.index == 1 %}
        <span class="podium-crown" aria-hidden="true">👑</span>
        <span class="podium-sparkle" aria-hidden="true"></span>
      {% endif %}
      <div class="flex items-center gap-3">
        <span class="medal {% if loop.index == 1 %}medal-shine {% endif %}text-lg">{{ loop.index }}</span>
        <div>
          <p class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">
            {% if loop.index == 1 %}Leader{% elif loop.index == 2 %}2nd place{% else %}3rd place{% endif %}
          </p>
          <p class="display text-lg text-slate-900">{{ entry.displayName }} <span class="font-normal text-slate-500 text-base">({{ entry.handle }})</span></p>
        </div>
      </div>
      <div class="mt-4 flex items-end justify-between">
        <span class="display text-4xl text-slate-900" data-countup="{{ entry.totalPoints }}" data-countup-delay="{{ riseDelay + 120 }}">0</span>
        <span class="text-xs text-slate-500">
          {% if loop.index == 1 %}
            <span class="text-champ-600 font-semibold">{{ medalLabel }} top of the table</span>
          {% else %}
            {{ behind }} pt behind leader
          {% endif %}
        </span>
      </div>
      <div class="mt-3">
        <div class="bar {% if loop.index == 1 %}bar-gold{% endif %}">
          <i class="animate-barFill" style="width: {{ (entry.totalPoints / maxScore * 100) | round(1) }}%; animation-delay: {{ riseDelay + 120 }}ms"></i>
        </div>
        <p class="text-[10px] text-slate-500 mt-1">{{ (entry.totalPoints / maxScore * 100) | round(1) }}% of {{ maxScore }} points won</p>
      </div>
    </article>
  {% endfor %}
</section>
{% elif leader.totalPoints == 0 %}
{# Nobody has scored yet → no meaningful podium. Stand-in hero: the cut-out
   ball (from asset/runner.png) rolls left→right across a white field on a loop.
   Returns to the podium automatically once any point lands. #}
<section class="dribble-banner mb-10" aria-label="Tournament under way — no points scored yet">
  <div class="dribble-pitch">
    <div class="dribble-copy">
      <p class="text-[10px] uppercase tracking-[0.25em] text-pitch-700 font-semibold mb-1">Kickoff</p>
      <h2 class="display text-2xl md:text-3xl text-slate-900">Tournament under way</h2>
      <p class="text-sm text-slate-600 mt-1">No points scored yet — first results land soon.</p>
    </div>
    <div class="dribble-track">
      <span class="dribble-shadow" aria-hidden="true"></span>
      <div class="dribble-bounce">
        <img src="/assets/ball.png" alt="" aria-hidden="true" class="dribble-ball">
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ─── Full table ───────────────────────────────────────────────────────── #}
<section>
  <h2 class="display text-lg text-slate-700 mb-3">Full standings</h2>
  <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-slate-200">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-slate-600">
      <tr class="text-[11px] uppercase tracking-wider">
        <th class="text-left  px-3 py-2.5 font-semibold w-10">#</th>
        <th class="text-left  px-3 py-2.5 font-semibold min-w-[9rem]">Player</th>
        <th class="text-left  px-3 py-2.5 font-semibold w-28">Points won</th>
        <th class="text-right px-3 py-2.5 font-semibold w-16">Total</th>
        <th class="text-left  px-3 py-2.5 font-semibold">Stages</th>
        <th class="text-right px-3 py-2.5 font-semibold w-14">TB</th>
      </tr>
    </thead>
    <tbody>
    {% for entry in leaderboard %}
      {% set isLeader = loop.index == 1 and entry.totalPoints > 0 %}
      <tr class="lb-row border-t border-slate-100 relative {% if isLeader %}gold-shimmer animate-goldShimmer{% endif %}">
        <td class="px-3 py-2.5 align-middle">
          {% if loop.index <= 3 and entry.totalPoints > 0 %}
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-[11px] font-bold
              {% if loop.index == 1 %}bg-champ-400 text-champ-700
              {% elif loop.index == 2 %}bg-slate-200 text-slate-700
              {% else %}bg-orange-200 text-orange-800{% endif %}">
              {{ loop.index }}
            </span>
          {% else %}
            <span class="text-slate-400 pl-1">{{ loop.index }}</span>
          {% endif %}
        </td>
        <td class="px-3 py-2.5 align-middle whitespace-nowrap">
          <span class="font-semibold text-slate-900">{{ entry.displayName }}</span> <span class="text-slate-500">({{ entry.handle }})</span>
        </td>
        <td class="px-3 py-2.5 align-middle">
          <div class="bar {% if isLeader %}bar-gold{% endif %}">
            <i class="animate-barFill" style="width: {{ (entry.totalPoints / maxScore * 100) | round(1) }}%; animation-delay: {{ loop.index0 * 60 }}ms"></i>
          </div>
        </td>
        <td class="px-3 py-2.5 align-middle text-right whitespace-nowrap">
          <span class="display text-lg {% if isLeader %}text-champ-700{% else %}text-slate-900{% endif %}">{{ entry.totalPoints }}</span>
        </td>
        <td class="px-3 py-2.5 align-middle">
          <div class="flex flex-wrap gap-1">
            {% if entry.pointsByStage.group > 0 %}
              <span class="chip" style="--chip-color: #0b6b3a">G {{ entry.pointsByStage.group }}</span>
            {% endif %}
            {% if entry.pointsByStage.r32 > 0 %}
              <span class="chip" style="--chip-color: #0ea5e9">R32 {{ entry.pointsByStage.r32 }}</span>
            {% endif %}
            {% if entry.pointsByStage.r16 > 0 %}
              <span class="chip" style="--chip-color: #6366f1">R16 {{ entry.pointsByStage.r16 }}</span>
            {% endif %}
            {% if entry.pointsByStage.qf > 0 %}
              <span class="chip" style="--chip-color: #a855f7">QF {{ entry.pointsByStage.qf }}</span>
            {% endif %}
            {% if entry.pointsByStage.sf > 0 %}
              <span class="chip" style="--chip-color: #ec4899">SF {{ entry.pointsByStage.sf }}</span>
            {% endif %}
            {% if entry.pointsByStage.final > 0 %}
              <span class="chip" style="--chip-color: #f97316">Final {{ entry.pointsByStage.final }}</span>
            {% endif %}
            {% if entry.pointsByStage.winner > 0 %}
              <span class="chip" style="--chip-color: #b08323">🏆 Winner {{ entry.pointsByStage.winner }}</span>
            {% endif %}
            {% if entry.totalPoints == 0 %}
              <span class="text-slate-400 text-xs italic">no points yet</span>
            {% endif %}
          </div>
        </td>
        <td class="px-3 py-2.5 align-middle text-right text-slate-500 text-xs whitespace-nowrap">
          {{ entry.tiebreaker if entry.tiebreaker != null else '—' }}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  <div class="mt-3">
    <p class="text-[11px] uppercase tracking-wider text-slate-500 font-semibold mb-1.5">Stage legend</p>
    <div class="flex flex-wrap gap-1">
      <span class="chip" style="--chip-color: #0b6b3a">G · Group</span>
      <span class="chip" style="--chip-color: #0ea5e9">R32 · Round of 32 (5)</span>
      <span class="chip" style="--chip-color: #6366f1">R16 · Round of 16 (10)</span>
      <span class="chip" style="--chip-color: #a855f7">QF · Quarter-Final (15)</span>
      <span class="chip" style="--chip-color: #ec4899">SF · Semi-Final (20)</span>
      <span class="chip" style="--chip-color: #f97316">Final (25)</span>
      <span class="chip" style="--chip-color: #b08323">🏆 Winner (30)</span>
    </div>
  </div>
  <p class="text-xs text-slate-500 mt-3">
    <strong>Points won</strong> bar = points / 960 max ·
    <strong>TB</strong> = tie-breaker prediction (total goals across all 104 matches, incl. extra time)
  </p>
</section>
</div>

{% endif %}

{# ─── Entry modal control ─────────────────────────────────────────────────
   Closing the modal remembers this state as "seen" (so it won't reappear until
   the state changes), then reveals the leaderboard and releases its held
   entrance animations. The countdown ticker only runs in the pre-kickoff
   state, when the digit tiles are present. #}
<script>
(function () {
  var modal = document.getElementById('wc-modal');
  if (!modal) return;

  var timer = null;
  var d = modal.querySelector('[data-d]');
  if (d) {
    // First match: Mexico vs South Africa, Mexico City, 11 Jun 2026 16:00 UTC.
    var KICKOFF = new Date('2026-06-11T16:00:00Z').getTime();
    var h = modal.querySelector('[data-h]');
    var m = modal.querySelector('[data-m]');
    var s = modal.querySelector('[data-s]');
    var pad = function (n) { return String(n).padStart(2, '0'); };
    var tick = function () {
      var ms = KICKOFF - Date.now();
      if (ms <= 0) {
        d.textContent = '00'; h.textContent = '00'; m.textContent = '00'; s.textContent = '00';
        clearInterval(timer);
        return;
      }
      d.textContent = pad(Math.floor(ms / 86400000));
      h.textContent = pad(Math.floor(ms / 3600000) % 24);
      m.textContent = pad(Math.floor(ms / 60000) % 60);
      s.textContent = pad(Math.floor(ms / 1000) % 60);
    };
    tick();
    timer = setInterval(tick, 1000);
  }

  function close() {
    modal.setAttribute('data-closed', 'true');
    if (timer) clearInterval(timer);
    document.documentElement.classList.remove('lb-gated');
    document.dispatchEvent(new CustomEvent('wc:ungate'));
  }
  modal.querySelectorAll('[data-close]').forEach(function (el) {
    el.addEventListener('click', function (e) { e.stopPropagation(); close(); });
  });
  modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
})();
</script>

{# ─── Podium score count-up ───────────────────────────────────────────────
   Ticks each podium total from 0 to its value, synced with the bar fill and
   the per-card rise stagger. Structured to re-run if scores ever update live. #}
<script>
(function () {
  var nums = document.querySelectorAll('[data-countup]');
  if (!nums.length) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) {
    nums.forEach(function (el) { el.textContent = el.getAttribute('data-countup'); });
    return;
  }
  function run(el) {
    var target = parseInt(el.getAttribute('data-countup'), 10) || 0;
    var delay = parseInt(el.getAttribute('data-countup-delay'), 10) || 0;
    var dur = 1100;
    setTimeout(function () {
      var start = null;
      requestAnimationFrame(function frame(ts) {
        if (start === null) start = ts;
        var p = Math.min((ts - start) / dur, 1);
        var eased = 1 - Math.pow(1 - p, 3); // easeOutCubic, matches the bar's feel
        el.textContent = Math.round(target * eased);
        if (p < 1) requestAnimationFrame(frame);
        else el.textContent = target;
      });
    }, delay);
  }
  function start() {
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { run(e.target); obs.unobserve(e.target); }
        });
      }, { threshold: 0.4 });
      nums.forEach(function (el) { io.observe(el); });
    } else {
      nums.forEach(run);
    }
  }
  // If the countdown modal is covering the page, hold the count-up until it's
  // closed (mirrors the CSS animation gate) so it isn't spent behind the overlay.
  if (document.documentElement.classList.contains('lb-gated')) {
    document.addEventListener('wc:ungate', start, { once: true });
  } else {
    start();
  }
})();
</script>
