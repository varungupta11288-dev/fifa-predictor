<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% if page.url and (page.url | string | safe).startsWith('/me/') %}
    <meta name="robots" content="noindex, nofollow">
  {% endif %}
  <title>{{ title or site.title }}</title>
  <meta name="theme-color" content="#0b6b3a">
  <link rel="icon" type="image/webp" href="{{ site.baseUrl }}/assets/trophy.webp">
  <link rel="stylesheet" href="{{ site.baseUrl }}/assets/css/tailwind.css">
</head>
<body class="turf-bg text-slate-900 antialiased min-h-screen flex flex-col">
  <header class="pitch-bg text-white relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 py-5 flex items-center justify-between relative z-10">
      <a href="{{ site.baseUrl }}/" class="flex items-center gap-3 group">
        <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/10 ring-1 ring-white/20 group-hover:bg-white/15 transition">
          <img src="{{ site.baseUrl }}/assets/trophy.webp" alt="" aria-hidden="true" class="w-6 h-6 object-contain">
        </span>
        <span class="display brand-gold text-xl md:text-2xl tracking-wider">WC2026 Predictor</span>
      </a>
      <nav class="space-x-1 text-xs md:text-sm uppercase tracking-wider font-semibold">
        <a href="{{ site.baseUrl }}/"        class="px-3 py-1.5 rounded hover:bg-white/10 transition">Leaderboard</a>
        <a href="{{ site.baseUrl }}/fixtures/" class="px-3 py-1.5 rounded hover:bg-white/10 transition">Fixtures</a>
        <a href="{{ site.baseUrl }}/how-to-enter/" class="px-3 py-1.5 rounded hover:bg-white/10 transition">How to enter</a>
        <a href="{{ site.baseUrl }}/rules/"   class="px-3 py-1.5 rounded hover:bg-white/10 transition">Rules</a>
      </nav>
    </div>
    {# Slow pitch-line pan behind the header content. #}
    <div class="absolute inset-0 opacity-40 animate-pitchPan"
         style="background-image: repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 38px, rgba(0,0,0,0.06) 38px, rgba(0,0,0,0.06) 76px);"></div>
  </header>

  {# Host-country flag stripe — gently sweeps via background-position animation. #}
  <div class="flag-stripe animate-flagSweep"></div>

  {% if site.tournamentLive %}
    {# Live banner — shown only during play. #}
    <div class="bg-slate-900 text-slate-100">
      <div class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between text-xs">
        <span class="flex items-center gap-2">
          <span class="live-dot animate-pulseDot"></span>
          <strong class="uppercase tracking-wider text-red-300">Live</strong>
          <span class="text-slate-300">·</span>
          <span>{{ site.countdownLabel }}</span>
        </span>
        <span class="text-slate-400 hidden sm:inline">{{ site.tournament.start }} → {{ site.tournament.end }}</span>
      </div>
    </div>
  {% else %}
    {# Host-country wordmark — drifts left↔right in time with the flag stripe above. #}
    <div class="bg-slate-900 text-slate-100 overflow-hidden">
      <div class="max-w-6xl mx-auto px-4 py-2 text-center">
        <span class="inline-block animate-flagText display uppercase text-xs sm:text-sm tracking-[0.3em] text-slate-200 whitespace-nowrap">
          FIFA 2026 <span class="text-slate-500">·</span> USA <span class="text-slate-500">·</span> Canada <span class="text-slate-500">·</span> Mexico
        </span>
      </div>
    </div>
  {% endif %}

  <main class="max-w-6xl mx-auto px-4 py-8 w-full flex-1">
    {{ content | safe }}
  </main>

  <footer class="bg-slate-900 mt-12">
    <div class="flag-stripe animate-flagSweep"></div>
  </footer>
</body>
</html>
